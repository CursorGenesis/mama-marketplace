# =============================================
#  НАСТРОЙКИ FIREBASE
# =============================================
#  1. Скопируй этот файл и назови его .env.local
#  2. Заполни значения из Firebase Console
# =============================================

NEXT_PUBLIC_FIREBASE_API_KEY=сюда_вставь_apiKey
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=сюда_вставь_authDomain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=сюда_вставь_projectId
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=сюда_вставь_storageBucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=сюда_вставь_messagingSenderId
NEXT_PUBLIC_FIREBASE_APP_ID=сюда_вставь_appId

# Email администратора (твой email)
NEXT_PUBLIC_ADMIN_EMAIL=tvoi_email@gmail.com
