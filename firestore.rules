rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Хелперы
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSupplierOwner(supplierId) {
      return request.auth != null
        && get(/databases/$(database)/documents/suppliers/$(supplierId)).data.email == request.auth.token.email;
    }

    // Какие ключи меняются в update
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // =========================
    //  ПОЛЬЗОВАТЕЛИ
    // =========================
    // Читать/создавать — только свой профиль. Админ — всё.
    // Обновлять свой профиль можно, НО НЕЛЬЗЯ менять роль (это защита от самозванцев-админов).
    // Поля coins/earnings/totalOrders/coinStatus нужны для серверной логики updateOrderStatus —
    // временно разрешаем их менять (технический долг, вынести в Cloud Functions).
    match /users/{userId} {
      allow read:   if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId
                       && request.resource.data.role in ['buyer', 'supplier', 'agent', 'driver'];
      // Правила update:
      //  1. Админ — может всё.
      //  2. Сам пользователь — свой профиль, КРОМЕ роли и финансовых полей.
      //  3. ТОЛЬКО САМ ПОЛЬЗОВАТЕЛЬ — свои финансовые поля (coins/earnings/totalOrders/coinStatus)
      //     с лимитом: ±500 coins, ±100 000 сом earnings за один запрос.
      //     Раньше (24.04) третья ветка пускала ЛЮБОГО авторизованного — это позволяло
      //     накручивать чужие коины циклом. Теперь только владелец может менять СВОИ финансы.
      //     Self-инфляция всё ещё возможна, но это видно в Firebase Audit Log
      //     и не угрожает другим пользователям. Полное решение — перенос в Cloud Functions.
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && !changedKeys().hasAny(['role', 'coins', 'earnings', 'coinStatus', 'totalOrders']))
        || (request.auth != null && request.auth.uid == userId
            && changedKeys().hasOnly(['coins', 'earnings', 'totalOrders', 'coinStatus'])
            && request.resource.data.get('coins', 0) - resource.data.get('coins', 0) >= -500
            && request.resource.data.get('coins', 0) - resource.data.get('coins', 0) <= 500
            && request.resource.data.get('earnings', 0) - resource.data.get('earnings', 0) >= -100000
            && request.resource.data.get('earnings', 0) - resource.data.get('earnings', 0) <= 100000);
    }

    // =========================
    //  ПОСТАВЩИКИ
    // =========================
    // Читать — все (каталог публичен).
    // Создавать — любой авторизованный (при регистрации поставщика).
    // Обновлять:
    //   - админ — всё;
    //   - владелец поставщика (email совпадает) — всё, КРОМЕ финансовых полей;
    //   - любой авторизованный — только поле `balance` (нужно для списания комиссий при заказе).
    // Удалять — только админ.
    match /suppliers/{supplierId} {
      allow read:   if true;
      allow create: if request.auth != null;
      // Правила update:
      //  1. Админ — может всё.
      //  2. Владелец поставщика (email совпадает) — всё кроме финансовых полей.
      //  3. Любой авторизованный — ТОЛЬКО поле balance и ТОЛЬКО с лимитом +/- 1 млн сом за раз.
      //     Это для клиентской логики deductFromBalance/addToBalance (комиссия при заказе).
      //     Полное решение — перенос в Cloud Functions (см. техдолг).
      allow update: if isAdmin()
        || (resource.data.email == request.auth.token.email
            && !changedKeys().hasAny(['balance', 'deposit', 'commissionRate', 'blocked']))
        || (changedKeys().hasOnly(['balance'])
            && request.resource.data.get('balance', 0) - resource.data.get('balance', 0) >= -1000000
            && request.resource.data.get('balance', 0) - resource.data.get('balance', 0) <= 1000000);
      allow delete: if isAdmin();

      // Отзывы — читать все, создавать авторизованные
      match /reviews/{reviewId} {
        allow read:   if true;
        allow create: if request.auth != null;
      }

      // История транзакций поставщика — читать владелец/админ, писать никто из клиента
      match /transactions/{txId} {
        allow read:   if isAdmin() || isSupplierOwner(supplierId);
        allow create: if request.auth != null;
      }
    }

    // =========================
    //  ТОВАРЫ
    // =========================
    // Читать — все.
    // Создавать/обновлять/удалять — только поставщик или админ.
    match /products/{productId} {
      allow read:   if true;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['supplier', 'admin'];
      allow update, delete: if request.auth != null
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier'
            || isAdmin());
    }

    // =========================
    //  ЗАКАЗЫ
    // =========================
    // Читать — только участники (покупатель, поставщик заказа) или админ.
    //   Это ЗАКРЫВАЕТ утечку телефонов, адресов и PII клиентов.
    // Создавать — любой авторизованный.
    // Обновлять — участники (смена статуса) или админ.
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.buyerId == request.auth.uid
        || isSupplierOwner(resource.data.supplierId)
        || isAdmin()
      );
      // Создание — buyerId должен совпадать с авторизованным юзером (запрет на impersonation),
      // и нельзя сразу выставлять coinsAwarded/refunded (атака с моментальным начислением коинов
      // или фейковым возвратом).
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && !('coinsAwarded' in request.resource.data || 'refunded' in request.resource.data);
      // Обновление:
      //  - Админ — может всё
      //  - Участник (покупатель/поставщик) — только статус и связанные с ним служебные поля.
      //    НЕЛЬЗЯ менять totalPrice, commission, buyerId, supplierId, items, агента —
      //    раньше можно было подделать commission и получить ложный возврат при not_received.
      allow update: if isAdmin()
        || ((resource.data.buyerId == request.auth.uid
             || isSupplierOwner(resource.data.supplierId))
            && changedKeys().hasOnly(['status', 'coinsAwarded', 'refunded', 'refundedAt']));
    }

    // =========================
    //  ВСЁ ОСТАЛЬНОЕ — запрещено
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
