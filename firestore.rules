rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Пользователи — читать свой профиль, писать только свой
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Поставщики — читать все, писать только админ и владелец
    match /suppliers/{supplierId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         resource.data.email == request.auth.token.email);
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Отзывы — читать все, писать авторизованные
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }

    // Товары — читать все, писать владелец и админ
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier');
    }

    // Заказы — читать свои, создавать авторизованные, обновлять участники
    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.supplierId != null ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Всё остальное — запрещено
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
